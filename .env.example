# URL base da Sales Dataset API REST (sem barra final)
SALES_API_BASE_URL=http://localhost:8000

# Timeout (segundos) para chamadas HTTP à Sales API
SALES_API_TIMEOUT=30

# Transporte do MCP: "stdio" para desenvolvimento (usado por `uv run mcp dev`)
# ou "sse" para servir via HTTP/SSE (usado em container).
MCP_TRANSPORT=stdio

# Host/porta usados quando MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8080
